---
import BaseLayout from '../layouts/BaseLayout.astro'

const title = 'Page not found | Andrea Valerio'
const description = 'The page you requested does not exist.'
---

<BaseLayout title={title} description={description}>
  <div class="w-full max-w-[1240px] mx-auto px-5 py-24 text-center">
    <p class="title-1 mb-4">404</p>
    <p class="body-1 mb-8">This page does not exist.</p>
    <a href={import.meta.env.BASE_URL} class="link-accent">Back to home</a>
  </div>
</BaseLayout>
